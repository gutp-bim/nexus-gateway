# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production

# Auth provider: "basic" (default) needs no external IdP — good for a single
# local install. Set to "keycloak" to use the Keycloak OIDC provider below
# instead (multi-site/SSO deployments).
AUTH_PROVIDER=basic

# Basic auth (used when AUTH_PROVIDER=basic, the default).
# ADMIN_PASSWORD has no default — Basic auth rejects every login until it is
# set, so a blank/unconfigured env can't silently grant access.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# Keycloak OIDC (used when AUTH_PROVIDER=keycloak; public values — safe to commit)
KEYCLOAK_ID=admin-ui
KEYCLOAK_SECRET=admin-ui-secret
# Browser-facing issuer (must match the iss claim in tokens).
KEYCLOAK_ISSUER=http://localhost:8090/realms/nexus-gateway
# Internal Docker hostname for server-side OIDC discovery (code exchange, token refresh).
# Uncomment when running inside Docker and the browser-facing URL is unreachable server-side.
# KEYCLOAK_INTERNAL_ISSUER=http://keycloak:8090/realms/nexus-gateway

# Admin API (server-side only — not NEXT_PUBLIC)
ADMIN_API_URL=http://gateway:8080
